{
  "name": "@0xsofia/design-system",
  "description": "Sofia design system — shared taxonomy, components, hooks, and styles across apps.",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./theme.css": "./src/theme.css",
    "./styles/bento.css": "./src/styles/bento.css",
    "./styles/favicon.css": "./src/styles/favicon.css",
    "./styles/verb-tag.css": "./src/styles/verb-tag.css",
    "./styles/user-badge.css": "./src/styles/user-badge.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": ">=0.180.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": ">=0.180.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
